# Source: CMRemote, clean-room implementation.
# Sample environment file consumed by cmremote-agent.service. Operators
# replace the values with the configuration handed to them by the server's
# enrolment flow (or by a configuration-management tool that produces
# /etc/cmremote/ConnectionInfo.json directly — that file takes precedence
# over these env vars). Both the .deb and .rpm packagers install this
# file to /etc/cmremote/agent.env mode 0640, owned by root:cmremote.

# Path to the agent's persisted ConnectionInfo.json (default).
CMREMOTE_CONFIG_DIR=/etc/cmremote

# Tracing filter (RUST_LOG syntax). "info" is a sensible default; bump
# to "debug" for diagnostics.
RUST_LOG=info
