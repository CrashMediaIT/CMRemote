@*
    Minimal layout used by the first-boot setup wizard skeleton (see
    SetupIndex.razor / ROADMAP.md "M1 — First-boot setup wizard"). The
    default MainLayout requires a signed-in, two-factor-enrolled user;
    the wizard is reached *before* any users exist, so it needs a
    layout that does not assume an authentication state.
*@
@inherits LayoutComponentBase

<div class="page">
    <div class="main">
        <div class="content">
            @Body
        </div>
    </div>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
